def print_receipts(items, copies):
    for i in range(1, items + 1):      # outer loop for items
        for j in range(copies):        # inner loop for copies
            print(f"Item {i}", end=" ")
        print()   # move to next line

# Input
items = int(input("Enter number of items: "))
copies = int(input("Enter number of copies: "))

# Function call
print_receipts(items, copies)
